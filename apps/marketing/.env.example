# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Email (lead capture via Resend REST API)
# Required for /api/subscribe to actually deliver signups. Without it the route
# degrades gracefully and logs a warning instead of crashing.
RESEND_API_KEY=
# Optional overrides for the subscribe route:
SUBSCRIBE_NOTIFY_TO=adam@ofmm.ie
EMAIL_FROM=The Hedge <hello@thehedge.ie>

# Stripe (Phase 3)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=https://thehedge.ie
